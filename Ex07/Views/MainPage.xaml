<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ex07.Views.MainPage"
             xmlns:viewmodels="clr-namespace:Ex07.ViewModels"
             xmlns:models="clr-namespace:Ex07.Models"
             x:DataType="viewmodels:MainViewModel"
             Title="Super Lista de Tarefas B-)">

    
    <Grid RowDefinitions="Auto, Auto, Auto, *" Padding="20" RowSpacing="10">
        
        <!-- LINHA 0: A BARRA DE BUSCA -->
        <SearchBar Grid.Row="0" 
           Placeholder="Pesquisar tarefa..." 
           Text="{Binding Filtro, Mode=TwoWay}" 
           SearchCommand="{Binding FiltrarTarefaCommand}" />

        <!-- Entrada de Dados -->
        <Grid Grid.Row="1" ColumnDefinitions="*, Auto" ColumnSpacing="10">
            <Entry Grid.Column="0"
                Placeholder="Digite uma nova tarefa..." 
                Text="{Binding NovaTarefa, Mode=TwoWay}" 
                FontSize="18" />

            <Picker Grid.Column="1" Title="Prio"
                WidthRequest="30"
                SelectedItem="{Binding PrioridadeSelecionada, Mode=TwoWay}">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>A</x:String>
                        <x:String>M</x:String>
                        <x:String>B</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>
        </Grid>

        <!-- Ação -->
        <Button Grid.Row="2"
            Text="Adicionar Tarefa" 
            Command="{Binding AdicionarTarefaCommand}" 
            BackgroundColor="#512BD4" 
            TextColor="White" />

        <!-- Visualização da Lista -->
        <Label Grid.Row="3"
            Text="Minhas Tarefas:"
            FontAttributes="Bold"
            Margin="0,10,0,0" />

        <CollectionView 
            Grid.Row="4"
            ItemsSource="{Binding TarefasFiltradas}"
            VerticalOptions="Fill">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="📝" FontSize="40" HorizontalOptions="Center" />
                    <Label Text="Lista Vazia" FontAttributes="Bold" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Tarefa">
                    <Frame BorderColor="#E1E1E1" Margin="0,5" Padding="10" HasShadow="True">
                        <!-- O segredo está no HorizontalOptions="FillAndExpand" ou no Grid -->
                        <Grid ColumnDefinitions="Auto, *, Auto"
                              RowDefinitions="Auto, Auto"
                              ColumnSpacing="10">

                            <!-- 1. O CheckBox: Conectado à propriedade 'Concluida' -->
                            <CheckBox Grid.Column="0" Grid.RowSpan="2" 
                                IsChecked="{Binding Concluida, Mode=TwoWay}" 
                                Color="#512BD4" />
                            
                            <!-- Texto da Tarefa: O '*' faz ele ocupar todo o espaço restante -->
                            <Label Grid.Column="1" Grid.Row="0"
                                Text="{Binding Nome}" 
                                FontSize="17" 
                                FontAttributes="Bold"
                                VerticalOptions="Center">
                                
                                <Label.Triggers>
                                    <!-- Se 'Concluida' for True, mude a cor e risque o texto -->
                                    <DataTrigger TargetType="Label" 
                                                Binding="{Binding Concluida}" 
                                                Value="True">
                                        <Setter Property="TextColor" Value="Gray" />
                                        <Setter Property="FontAttributes" Value="Italic" />
                                        <Setter Property="TextDecorations" Value="Strikethrough" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <!-- Linha 1, Coluna 1: Data e Hora (O NOVO!) -->
                            <Label Grid.Column="1" Grid.Row="1" FontSize="11" TextColor="Gray">
                                <Label.Text>
                                    <MultiBinding StringFormat="Criado em: {0:dd/MM/yyyy HH:mm} | Prio: {1}">
                                        <Binding Path="DataCriacao" />
                                        <Binding Path="Prioridade" />
                                    </MultiBinding>
                                </Label.Text>

                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding Concluida}" Value="True">
                                        <Setter Property="Text" Value="{Binding DataConclusao, StringFormat='Concluído em: {0:dd/MM HH:mm}'}" />
                                        <Setter Property="TextColor" Value="Green" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <!-- Botão de Remover: O 'Auto' faz ele ocupar apenas o seu próprio tamanho -->
                            <Button Grid.Column="2" Grid.RowSpan="2"
                                Text="🗑"
                                BackgroundColor="Transparent" 
                                TextColor="Red"
                                VerticalOptions="Center"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=RemoverTarefaCommand}"
                                CommandParameter="{Binding .}" /> 
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>  
        </CollectionView>

    </Grid>
</ContentPage>