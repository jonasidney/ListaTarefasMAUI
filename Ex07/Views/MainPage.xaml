<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ex07.Views.MainPage"
             xmlns:viewmodels="clr-namespace:Ex07.ViewModels"
             xmlns:models="clr-namespace:Ex07.Models"
             x:DataType="viewmodels:MainViewModel"
             Title="Super Lista de Tarefas B-)">

    
    <Grid RowDefinitions="Auto, Auto, *" Padding="20" RowSpacing="15">
        
        <!-- Entrada de Dados -->
        <Entry Grid.Row="0"
            Placeholder="Digite uma nova tarefa..." 
            Text="{Binding NovaTarefa, Mode=TwoWay}" 
            FontSize="18" />

        <!-- Ação -->
        <Button Grid.Row="1"
            Text="Adicionar Tarefa" 
            Command="{Binding AdicionarTarefaCommand}" 
            BackgroundColor="#512BD4" 
            TextColor="White" />

        <!-- Visualização da Lista -->
        <Label Grid.Row="2"
            Text="Minhas Tarefas:"
            FontAttributes="Bold"
            Margin="0,10,0,0" />

        <CollectionView 
            Grid.Row="3"
            ItemsSource="{Binding Tarefas}"
            VerticalOptions="Fill">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="📝" FontSize="40" HorizontalOptions="Center" />
                    <Label Text="Lista Vazia" FontAttributes="Bold" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Tarefa">
                    <Frame BorderColor="#E1E1E1" Margin="0,5" Padding="10" HasShadow="True">
                        <!-- O segredo está no HorizontalOptions="FillAndExpand" ou no Grid -->
                        <Grid ColumnDefinitions="Auto, *, Auto"
                              RowDefinitions="Auto, Auto"
                              ColumnSpacing="10">

                            <!-- 1. O CheckBox: Conectado à propriedade 'Concluida' -->
                            <CheckBox Grid.Column="0" Grid.RowSpan="2" 
                                IsChecked="{Binding Concluida, Mode=TwoWay}" 
                                Color="#512BD4" />
                            
                            <!-- Texto da Tarefa: O '*' faz ele ocupar todo o espaço restante -->
                            <Label Grid.Column="1" Grid.Row="0"
                                Text="{Binding Nome}" 
                                FontSize="17" 
                                FontAttributes="Bold"
                                VerticalOptions="Center">
                                
                                <Label.Triggers>
                                    <!-- Se 'Concluida' for True, mude a cor e risque o texto -->
                                    <DataTrigger TargetType="Label" 
                                                Binding="{Binding Concluida}" 
                                                Value="True">
                                        <Setter Property="TextColor" Value="Gray" />
                                        <Setter Property="FontAttributes" Value="Italic" />
                                        <Setter Property="TextDecorations" Value="Strikethrough" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <!-- Linha 1, Coluna 1: Data e Hora (O NOVO!) -->
                            <Label Grid.Column="1" Grid.Row="1"
                                Text="{Binding DataCriacao, StringFormat='Criado em: {0:dd/MM/yyyy HH:mm}'}"
                                FontSize="11" 
                                TextColor="Gray" />

                            <!-- Botão de Remover: O 'Auto' faz ele ocupar apenas o seu próprio tamanho -->
                            <Button Grid.Column="2" Grid.RowSpan="2"
                                Text="🗑"
                                BackgroundColor="Transparent" 
                                TextColor="Red"
                                VerticalOptions="Center"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=RemoverTarefaCommand}"
                                CommandParameter="{Binding .}" /> 
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>  
        </CollectionView>

    </Grid>
</ContentPage>